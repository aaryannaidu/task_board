# ============================================================
# Root .gitignore for Task Board (COP290 Assignment 2)
# ============================================================

# --------------------------
# macOS
# --------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --------------------------
# Editor / IDE
# --------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --------------------------
# Node / npm
# --------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# --------------------------
# TypeScript Build Output
# --------------------------
dist/
dist-ssr/
build/
*.tsbuildinfo

# --------------------------
# Environment Files (NEVER commit these)
# --------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --------------------------
# Prisma
# --------------------------
/backend/generated/prisma
/backend/prisma/migrations
/prisma/migrations

# --------------------------
# Test Coverage
# --------------------------
coverage/
*.lcov

# --------------------------
# Misc
# --------------------------
*.local
*.pem

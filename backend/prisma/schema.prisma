generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum GlobalRole{
  ADMIN
  MEMBER
}
enum ProjectRole{
  ADMIN
  MEMBER
  VIEWER
}
enum TaskType{
  STORY
  TASK
  BUG
}
enum Priority{
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User{
  id Int @id @default(autoincrement())
  email String @unique
  passwordHash String
  avatarUrl String?
  name String
  globalRole GlobalRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  refreshTokens RefreshToken[]
  projectMembers ProjectMember[]
  assignedTasks Task[] @relation("Assignee")
  reportedTasks Task[] @relation("Reporter")
  comments Comment[]
  auditAction AuditLog[]
  notifications Notification[]
}
model RefreshToken{
id Int @id @default(autoincrement())
token String @unique
userID Int
user User @relation(fields: [userID], references: [id], onDelete: Cascade)
createdAt DateTime @default(now())
expiresAt DateTime
}

model Project{
  id Int @id @default(autoincrement())
  name String
  description String?
  archived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectMembers ProjectMember[]
  boards Board[]

}
model ProjectMember{
  id Int @id @default(autoincrement())
  userID Int
  projectID Int
  role ProjectRole @default(MEMBER)
  user User @relation (fields:[userID], references:[id], onDelete: Cascade)
  project Project @relation(fields:[projectID], references: [id], onDelete: Cascade) 
  @@unique([userID, projectID])
}

model Board{
  id Int @id @default(autoincrement())
  name String
  projectID Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project Project @relation(fields:[projectID],references:[id],onDelete:Cascade)
  columns Column[]
  transitions WorkTransition[]
}
model Column{
  id Int @id @default(autoincrement())
  name String
  order Int
  wipLimit Int?
  boardID Int
  board Board @relation(fields:[boardID],references:[id],onDelete:Cascade)
  tasks Task[]
}
model WorkTransition{
  id Int @id @default(autoincrement())
  boardID Int
  board Board @relation(fields:[boardID],references:[id],onDelete:Cascade)
  fromStatus String
  toStatus String
  @@unique([boardID,fromStatus,toStatus])
}
model Task{
  id Int @id@default(autoincrement())
  title String
  description String?
  type TaskType @default(TASK)
  priority Priority @default(MEDIUM)
  status String @default ("TO DO")
  dueDate DateTime? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parentID Int?
  Parent Task? @relation("Parentchild",fields:[parentID],references:[id],onDelete: Cascade)
  children Task[] @relation("Parentchild")
  columnID Int
  column Column @relation(fields:[columnID],references:[id],onDelete:Cascade)
  assigneeID Int?
  assignee User? @relation("Assignee",fields:[assigneeID],references:[id],onDelete: SetNull)
  reporterID Int
  reporter User @relation("Reporter",fields:[reporterID],references:[id],onDelete:SetNull)
  comments Comment[]
  resolveAt DateTime?
  closedAt DateTime?
  auditLogs AuditLog[]
  notifications Notification[]
  @@index([columnID])
  @@index([assigneeID])
  @@index([reporterID])
}
model Comment{
  id Int @id @default(autoincrement())
  content String
  taskID Int
  task Task @relation (fields:[taskID],references:[id],onDelete:Cascade)
  authorID Int
  author User @relation(fields:[authorID],references:[id],onDelete:Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model AuditLog{
  id Int @id @default (autoincrement())
  taskID Int
  task Task @relation(fields:[taskID],references:[id],onDelete:Cascade)
  actorId Int
  actor User@relation(fields:[actorId],references:[id],onDelete:Cascade)
  eventtype String
  oldValue String?
  newValue String?
  createdAt DateTime @default(now())
  @@index([taskID])
}
model Notification{
  id Int@id @default(autoincrement())
  type String
  message String
  userID Int
  user User @relation(fields:[userID],references:[id],onDelete:Cascade)
  taskID Int?
  task Task? @relation(fields:[taskID],references:[id],onDelete: Cascade)
  createdAt DateTime@default(now())
  read Boolean @default(false)
  @@index([userID])

}
